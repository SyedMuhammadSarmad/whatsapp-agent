# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Meta Cloud API — WhatsApp text messaging (Phase 1, required now) ──────────
# developers.facebook.com → your app → WhatsApp → Getting Started
META_PHONE_NUMBER_ID=''        # numeric ID shown next to your test number
META_ACCESS_TOKEN=''           # temporary dev token (or permanent system user token)
META_APP_SECRET=''             # App → Settings → Basic → App Secret
META_VERIFY_TOKEN=my-secret-42  # any string you choose; paste the same in Meta console

# ── Asana ─────────────────────────────────────────────────────────────────────
ASANA_ACCESS_TOKEN=...          # app.asana.com → Profile → Apps → Personal access token
ASANA_WORKSPACE_ID=...          # from Asana URL: app.asana.com/0/<workspace_id>/...

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker:  redis://localhost:6379
# Upstash free:  rediss://:password@host:port
REDIS_URL=redis://localhost:6379

# ── Twilio — voice calling (Phase 3, leave empty for now) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
